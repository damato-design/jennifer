---
import Head from '@components/Head.astro';
import Navigation from '@components/Navigation.astro';
import Footer from '@components/Footer.astro';
---

<!doctype html>
<html lang="en">
<Head title="Résumé — Jennifer D'Amato" desc="Lead Experience Designer specialising in design systems and accessibility."/>
<body>
    <a href="#resume-content" class="skip-link">Skip to content</a>
    <Navigation/>

    <main id="resume-content">

        <!-- MASTHEAD -->
        <header class="resume-header max-width">
            <div class="header-accent"></div>
            <div class="header-body">
                <div class="header-left">
                    <h1 class="resume-name">Jennifer D'Amato</h1>
                    <p class="resume-title">Lead Experience Designer · Design Systems &amp; Accessibility</p>
                    <div class="resume-contact">
                        <a href="mailto:jennifer@damato.design" class="contact-item">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16"/><path d="m2 4 10 9 10-9"/></svg>
                            jennifer@damato.design
                        </a>
                        <span class="sep">&middot;</span>
                        <a href="tel:3474337446" class="contact-item">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-7.92-7.92 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 2.18 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 7.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16z"/></svg>
                            (347) 433-7446
                        </a>
                        <span class="sep">&middot;</span>
                        <a href="https://jennifer.damato.design" class="contact-item">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                            jennifer.damato.design
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- BODY -->
        <div class="resume-body max-width">

            <!-- SIDEBAR -->
            <aside class="sidebar">

                <section class="sidebar-section">
                    <h2 class="section-label">Skills</h2>
                    <ul class="skill-list">
                        <li>Accessibility</li>
                        <li>Design Systems</li>
                        <li>UX Design</li>
                        <li>User Research</li>
                        <li>Visual Design</li>
                        <li>Art Direction</li>
                        <li>Prototyping</li>
                        <li>Documentation</li>
                        <li>HTML / CSS</li>
                        <li>Design Education</li>
                    </ul>
                </section>

                <section class="sidebar-section">
                    <h2 class="section-label">Tools</h2>
                    <ul class="skill-list">
                        <li>Figma</li>
                        <li>Adobe Creative Cloud</li>
                        <li>zeroheight</li>
                        <li>Copilot Studio</li>
                        <li>Claude</li>
                        <li>Jira</li>
                        <li>Miro</li>
                        <li>Microsoft Suite</li>
                    </ul>
                </section>

                <section class="sidebar-section">
                    <h2 class="section-label">Education</h2>
                    <div class="edu-item">
                        <div class="edu-school">Pratt Institute</div>
                        <div class="edu-degree">M.S. Communications Design</div>
                    </div>
                    <div class="edu-item">
                        <div class="edu-school">City College of New York</div>
                        <div class="edu-degree">B.A. Electronic Design &amp; Multimedia</div>
                    </div>
                </section>

                <section class="sidebar-section">
                    <h2 class="section-label">Continuous Learning</h2>
                    <ul class="learn-list">
                        <li>Leadership Academy <span class="learn-org">Rare with Google</span></li>
                        <li>UX Design <span class="learn-org">General Assembly</span></li>
                        <li>Full-Stack Web Development <span class="learn-org">City Tech</span></li>
                        <li>Storytelling &amp; Improv <span class="learn-org">Magnet Theater</span></li>
                        <li>Dale Carnegie Course <span class="learn-org">Dale Carnegie</span></li>
                    </ul>
                </section>

            </aside>

            <!-- EXPERIENCE -->
            <section class="experience">
                <h2 class="section-label">Experience</h2>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">Signet Jewelers</span>
                            <span class="job-dates">2024 — Present</span>
                        </div>
                        <h3 class="job-title">Lead Experience Designer, Amor Design System</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Design lead building the Amor Design System for commerce and store associate tools across the world's largest diamond jewelry retailer</li>
                        <li>Leading a shift toward scalable semantic token naming conventions</li>
                        <li>Accessibility design lead for the Digital Experience Design team</li>
                        <li>Team culture member supporting engagement and wellness initiatives</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">Signet Jewelers</span>
                            <span class="job-dates">2021 — 2024</span>
                        </div>
                        <h3 class="job-title">Senior Experience Designer, Amor Design System</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Built and maintained design system documentation supporting multiple brands</li>
                        <li>Collaborated with UX designers, researchers, content writers, product owners, and engineers</li>
                        <li>Design lead for accessibility inquiries across the experience design team</li>
                        <li>Contributed to product feature development through prototypes and specifications</li>
                        <li>Founding member of team culture initiatives</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">CareerFoundry</span>
                            <span class="job-dates">2021 — 2025</span>
                        </div>
                        <h3 class="job-title">UI &amp; UX Tutor</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Instructed aspiring designers in design thinking, UX research, information architecture, prototyping, design systems, accessibility, and portfolio refinement</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">The College Board</span>
                            <span class="job-dates">2019 — 2021</span>
                        </div>
                        <h3 class="job-title">Senior Visual Designer</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Led design of College Board's first fully digital event</li>
                        <li>Visual lead for website re-platforming initiative across six brand properties</li>
                        <li>Collaborated across teams to ensure seamless cross-platform experiences</li>
                        <li>Managed branding for a new international office</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">The College Board</span>
                            <span class="job-dates">2013 — 2019</span>
                        </div>
                        <h3 class="job-title">Visual Designer</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Refreshed company presentation standards and brand guidelines</li>
                        <li>Delivered work across web, digital, print, environmental, and video platforms</li>
                        <li>Designed and led 14 annual College Board events</li>
                        <li>Applied mobile-responsive design and web accessibility expertise</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">Vuwable</span>
                            <span class="job-dates">2018</span>
                        </div>
                        <h3 class="job-title">UI Designer</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Refined user experience and interface design for the principal website</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">Van Gennep Design</span>
                            <span class="job-dates">2012 — 2013</span>
                        </div>
                        <h3 class="job-title">Associate Designer</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Provided creative solutions for nonprofits and cultural institutions including the Apollo Theater, The Noguchi Museum, and Planned Parenthood NYC</li>
                    </ul>
                </article>

                <article class="job">
                    <div class="job-header">
                        <div class="job-meta">
                            <span class="job-company">CityPockets</span>
                            <span class="job-dates">2011</span>
                        </div>
                        <h3 class="job-title">Designer</h3>
                    </div>
                    <ul class="job-bullets">
                        <li>Designed user interface for the debut mobile app and delivered production assets</li>
                    </ul>
                </article>

            </section>
        </div>
    </main>

    <Footer/>
</body>
</html>

<style>
    /* ---- Layout ---- */
    .resume-header {
        padding-block: 2.5rem 0;
        border-bottom: 2px solid var(--ink);
    }

    .header-accent {
        height: 3px;
        background: var(--red);
        margin-bottom: 1.75rem;
    }

    .header-body {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
        padding-bottom: 2rem;
    }

    .resume-name {
        font-family: var(--font-serif);
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1;
        margin: 0 0 0.5rem;
        color: var(--ink);
    }

    .resume-title {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--neutral-500);
        margin: 0 0 0.875rem;
    }

    .resume-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.06em;
        color: var(--neutral-500);
    }

    .contact-item {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .resume-contact a {
        color: var(--neutral-500);
        text-decoration: none;
        transition: color 0.15s;
    }

    .resume-contact a:hover {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--red);
        text-underline-offset: 3px;
    }

    .sep { color: var(--muted); }

    .print-btn {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: transparent;
        border: 1.5px solid var(--ink);
        color: var(--ink);
        padding: 0.5rem 1rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .print-btn:hover {
        background: var(--ink);
        color: var(--paper);
    }

    .print-btn:focus-visible {
        outline: 2px solid var(--ink);
        outline-offset: 2px;
    }

    /* ---- Two-column body ---- */
    .resume-body {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 0;
        padding-bottom: 4rem;
    }

    /* ---- Sidebar ---- */
    .sidebar {
        border-left: 1.5px solid var(--ink);
        padding: 2rem 0 2rem 2rem;
        order: 2;
    }

    .sidebar-section {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--muted);
    }

    .sidebar-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    /* ---- Experience ---- */
    .experience {
        padding: 2rem 2.5rem 2rem 0;
        order: 1;
    }

    /* ---- Shared section label ---- */
    .section-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--neutral-500);
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1.5px solid var(--ink);
    }

    /* ---- Skills ---- */
    .skill-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .skill-list li {
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--neutral-600);
        padding: 0.3rem 0;
        border-bottom: 1px solid var(--muted);
        line-height: 1.4;
    }

    .skill-list li:last-child { border-bottom: none; }

    /* ---- Education ---- */
    .edu-item {
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--muted);
    }

    .edu-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .edu-school {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 0.125rem;
    }

    .edu-degree {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.06em;
        color: var(--neutral-500);
        line-height: 1.5;
    }

    /* ---- Continuous learning ---- */
    .learn-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .learn-list li {
        font-family: var(--font-body);
        font-size: 0.8125rem;
        color: var(--neutral-600);
        line-height: 1.4;
    }

    .learn-org {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.575rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--neutral-500);
        margin-top: 0.125rem;
    }

    /* ---- Job entries ---- */
    .job {
        margin-bottom: 0;
        padding-block: 1.5rem;
        border-bottom: 1px solid var(--muted);
    }

    .job:first-of-type { padding-top: 0; }
    .job:last-child { border-bottom: none; }

    .job-header {
        margin-bottom: 0.625rem;
    }

    .job-meta {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.25rem;
    }

    .job-company {
        font-family: var(--font-serif);
        font-size: 1.0625rem;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -0.01em;
    }

    .job-dates {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: var(--neutral-500);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .job-title {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--red);
        margin: 0;
        font-weight: 500;
    }

    .job-bullets {
        list-style: none;
        margin: 0.625rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .job-bullets li {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--neutral-600);
        padding-left: 1rem;
        position: relative;
    }

    .job-bullets li::before {
        content: '·';
        position: absolute;
        left: 0;
        color: var(--neutral-400);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        top: 0.2em;
    }

    /* ---- Responsive ---- */
    @media (max-width: 640px) {
        .resume-body {
            grid-template-columns: 1fr;
        }

        .sidebar {
            border-right: none;
            border-bottom: 2px solid var(--ink);
            padding: 2rem 0;
        }

        .experience {
            padding: 2rem 0;
        }

        .header-body {
            flex-direction: column;
            align-items: flex-start;
        }

        .print-btn {
            align-self: flex-start;
        }
    }

    /* ---- Print styles ---- */
    @media print {
        nav, footer, .print-btn { display: none !important; }

        body {
            background: white;
            color: black;
        }

        .resume-header, .resume-body {
            max-width: 100%;
        }

        .job { page-break-inside: avoid; }

        .resume-name { font-size: 2rem; }
    }
</style>
