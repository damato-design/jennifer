---
import zigzagRaw from '../assets/chaos-zigzag.svg?raw';
const zigzagBg = `url("data:image/svg+xml,${encodeURIComponent(zigzagRaw)}")`;
---
<span class="chaos-word" aria-label="chaos"><span class="chaos-letter" aria-hidden="true">c</span><span class="chaos-letter" aria-hidden="true">h</span><span class="chaos-letter" aria-hidden="true">a</span><span class="chaos-letter" aria-hidden="true">o</span><span class="chaos-letter" aria-hidden="true">s</span></span>

<style define:vars={{ zigzagBg }}>
    .chaos-word {
        display: inline-block;
        position: relative;
        padding-bottom: 8px;
        transform-origin: center bottom;
        transition: transform 0.15s ease;
    }

    .chaos-word::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 6px;
        background-image: var(--zigzagBg);
        background-repeat: repeat-x;
        background-size: 10px 6px;
    }

    .chaos-letter {
        display: inline-block;
    }

    .chaos-word:hover,
    .chaos-word:focus-within {
        transform: scale(2);
    }

    .chaos-word:hover .chaos-letter:nth-child(1),
    .chaos-word:focus-within .chaos-letter:nth-child(1) { animation: chaos-1 1.73s linear infinite; }
    .chaos-word:hover .chaos-letter:nth-child(2),
    .chaos-word:focus-within .chaos-letter:nth-child(2) { animation: chaos-2 1.09s linear infinite; }
    .chaos-word:hover .chaos-letter:nth-child(3),
    .chaos-word:focus-within .chaos-letter:nth-child(3) { animation: chaos-3 1.61s linear infinite; }
    .chaos-word:hover .chaos-letter:nth-child(4),
    .chaos-word:focus-within .chaos-letter:nth-child(4) { animation: chaos-4 1.91s linear infinite; }
    .chaos-word:hover .chaos-letter:nth-child(5),
    .chaos-word:focus-within .chaos-letter:nth-child(5) { animation: chaos-5 1.83s linear infinite; }

    /* Unequal keyframe spacing = speed variation: packed stops snap fast, spread stops drift slow */
    @keyframes chaos-1 {
        0%   { transform: translate(  0px,  0px) rotate(  0deg); }
        6%   { transform: translate(-15px,-10px) rotate(-45deg); }
        15%  { transform: translate( 12px,-14px) rotate( 28deg); }
        35%  { transform: translate( -8px,  8px) rotate(-20deg); }
        41%  { transform: translate(  1px,  2px) rotate( -8deg); }
        55%  { transform: translate( 18px,  4px) rotate( 50deg); }
        62%  { transform: translate(  2px,-16px) rotate(-35deg); }
        78%  { transform: translate(-14px,  5px) rotate( 40deg); }
        88%  { transform: translate( -2px, -2px) rotate( 12deg); }
        100% { transform: translate(  0px,  0px) rotate(  0deg); }
    }

    @keyframes chaos-2 {
        0%   { transform: translate(  0px,  0px) rotate(  0deg); }
        9%   { transform: translate( 16px,  8px) rotate( 55deg); }
        19%  { transform: translate( -4px,-18px) rotate(-30deg); }
        28%  { transform: translate( -4px,-18px) rotate(-62deg); }
        45%  { transform: translate( 14px, 12px) rotate( 20deg); }
        52%  { transform: translate( -1px,  3px) rotate( -5deg); }
        66%  { transform: translate(-20px, -6px) rotate(-48deg); }
        73%  { transform: translate(  8px,-10px) rotate( 35deg); }
        88%  { transform: translate(  2px, 16px) rotate(-15deg); }
        100% { transform: translate(  0px,  0px) rotate(  0deg); }
    }

    @keyframes chaos-3 {
        0%   { transform: translate(  0px,  0px) rotate(  0deg); }
        5%   { transform: translate( 10px,  8px) rotate( 32deg); }
        11%  { transform: translate(-12px,  2px) rotate(-40deg); }
        18%  { transform: translate(  6px,-10px) rotate( 22deg); }
        27%  { transform: translate( -3px,  0px) rotate( -8deg); }
        44%  { transform: translate(-16px,  8px) rotate(-52deg); }
        53%  { transform: translate( 12px, 14px) rotate( 28deg); }
        61%  { transform: translate( -2px, -2px) rotate( 15deg); }
        74%  { transform: translate( 14px, -8px) rotate(-35deg); }
        85%  { transform: translate( -8px,  6px) rotate( 45deg); }
        100% { transform: translate(  0px,  0px) rotate(  0deg); }
    }

    @keyframes chaos-4 {
        0%   { transform: translate(  0px,  0px) rotate(  0deg); }
        8%   { transform: translate(-18px, 10px) rotate(-40deg); }
        22%  { transform: translate(  8px,-20px) rotate( 25deg); }
        38%  { transform: translate( 18px, 12px) rotate( 58deg); }
        46%  { transform: translate(  0px,  2px) rotate( 10deg); }
        60%  { transform: translate(-14px,-16px) rotate(-30deg); }
        68%  { transform: translate(  3px, -4px) rotate(-48deg); }
        80%  { transform: translate( 20px,  8px) rotate( 35deg); }
        90%  { transform: translate(  2px, -2px) rotate(-15deg); }
        100% { transform: translate(  0px,  0px) rotate(  0deg); }
    }

    @keyframes chaos-5 {
        0%   { transform: translate(  0px,  0px) rotate(  0deg); }
        7%   { transform: translate( 14px,-12px) rotate( 42deg); }
        13%  { transform: translate(-10px, -8px) rotate(-28deg); }
        24%  { transform: translate(  2px, 14px) rotate( 15deg); }
        32%  { transform: translate(-16px,  4px) rotate(-55deg); }
        40%  { transform: translate(  1px, -1px) rotate(  8deg); }
        56%  { transform: translate( 12px, 16px) rotate(-20deg); }
        67%  { transform: translate(-14px,  2px) rotate( 38deg); }
        77%  { transform: translate(  6px,-14px) rotate(-42deg); }
        87%  { transform: translate( -3px,  3px) rotate( 20deg); }
        100% { transform: translate(  0px,  0px) rotate(  0deg); }
    }

    @media (prefers-reduced-motion: reduce) {
        .chaos-word:hover,
        .chaos-word:focus-within { transform: none; }
        .chaos-word:hover .chaos-letter,
        .chaos-word:focus-within .chaos-letter { animation: none; }
    }
</style>
