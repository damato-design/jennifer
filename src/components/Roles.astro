---
const { roles } = Astro.props;
---

<style>
    ul {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    li {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink);
        padding: 0.25rem 0;
        border-bottom: 1px solid var(--muted);
        white-space: normal;
    }

    li:last-child {
        border-bottom: none;
    }
</style>

<ul>
    { roles.map((role: string) => <li>{ role }</li>) }
</ul>
