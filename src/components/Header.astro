---
const { accent, title, desc } = Astro.props;
const accentColor = accent || 'var(--ink)';
---

<style define:vars={{ accentColor }}>
    header {
        background: var(--paper);
        padding-block: 2.25rem 0;
        position: relative;
    }

    .accent-rule {
        height: 4px;
        background: var(--accentColor);
        margin-bottom: clamp(0.75rem, 2vw, 1rem);
        width: 100%;
    }

    .label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--neutral-500);
        margin-bottom: 1rem;
        display: block;
    }

    h1 {
        font-family: var(--font-serif);
        font-size: clamp(2.25rem, 6vw, 4.125rem);
        font-weight: 900;
        line-height: 1.0;
        letter-spacing: -0.03em;
        margin: 0 0 1.25rem;
        color: var(--ink);
        max-width: 20ch;
    }

    .desc {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--neutral-600);
        max-width: 55ch;
        margin: 0;
    }
</style>

<header>
    <div class="max-width">
        <div class="accent-rule"></div>
        <h1>{ title }</h1>
        <p class="desc">{ desc }</p>
    </div>
</header>
